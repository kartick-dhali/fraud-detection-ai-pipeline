{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowDatabricksAssumeRoleWithExternalId",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::414351767826:root"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "2ced7911-e55a-4495-9893-37c4eda9f023"
        }
      }
    },
    {
      "Sid": "AllowSelfAssumeForValidation",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::346720668814:root"
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
